# Copiar este archivo como .env y completar los valores reales.
# El .env NO debe subirse al repositorio (esta en .gitignore).

# Clave secreta de Flask. Generar una nueva con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambiar-por-un-valor-aleatorio

# Ruta absoluta de la base SQLite (opcional, fallback).
# Si se omite, se usa <proyecto>/instance/inventory.db
# DATABASE_PATH=C:\ruta\a\inventory.db

# Conexión a Base de Datos (MySQL, PostgreSQL, etc.)
# Si se define, tiene prioridad sobre DATABASE_PATH y SQLite.
# Para MySQL (requiere PyMySQL):
# DATABASE_URL=mysql+pymysql://usuario:contraseña@servidor:3306/nombre_base

# Modo desarrollo. Dejar en 0 (o vacio) salvo que se quiera el reloader/debugger.
# NUNCA poner FLASK_DEBUG=1 con FLASK_HOST=0.0.0.0 (ejecucion remota de codigo).
FLASK_DEBUG=0
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Passwords iniciales de los usuarios seed.
# Solo se usan cuando el usuario NO existe todavia en la DB.
# Si los usuarios ya estan creados, cambiar estas variables no afecta las contrasenas actuales.
# Reemplazar por valores reales en .env (NO commitear).
ADMIN_PASSWORD=<definir-en-.env>
JUAN_PASSWORD=<definir-en-.env>
RICARDO_PASSWORD=<definir-en-.env>
